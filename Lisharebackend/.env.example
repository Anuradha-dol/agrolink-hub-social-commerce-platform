DB_URL=jdbc:postgresql://localhost:5432/bodlyy_db
DB_USERNAME=postgres
DB_PASSWORD=change_me
JPA_DDL_AUTO=update

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_app_password

SERVER_PORT=4041
FILE_UPLOAD_DIR=uploads

# Base64-encoded secret (at least 256-bit key)
JWT_SECRET=replace_with_base64_secret
JWT_ACCESS_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000
JWT_VERIFY_EXPIRATION_MS=1800000

COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
COOKIE_DOMAIN=
COOKIE_PATH=/

APP_CORS_ALLOWED_ORIGINS=http://localhost:[*],http://127.0.0.1:[*]
