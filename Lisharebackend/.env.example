DB_URL=jdbc:postgresql://localhost:5432/bodlyy_db
DB_USERNAME=postgres
DB_PASSWORD=change_me
JPA_DDL_AUTO=update

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_app_password

SERVER_PORT=8081
FILE_UPLOAD_DIR=uploads

GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8081/login/oauth2/code/google
APP_OAUTH2_SUCCESS_REDIRECT=http://localhost:5173/oauth2/callback
APP_OAUTH2_FAILURE_REDIRECT=http://localhost:5173/login

# Base64-encoded secret (at least 256-bit key)
JWT_SECRET=replace_with_base64_secret
JWT_ACCESS_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000
JWT_VERIFY_EXPIRATION_MS=1800000

COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
COOKIE_DOMAIN=
COOKIE_PATH=/

APP_CORS_ALLOWED_ORIGINS=http://localhost:[*],http://127.0.0.1:[*]

# Production checklist:
# COOKIE_SECURE=true
# APP_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.example
# COOKIE_DOMAIN=your-api-domain.example (only if your deployment needs it)
# Keep COOKIE_SAME_SITE=Lax unless you intentionally deploy cross-site cookies.

# Upload limits in bytes. Keep media high enough for videos, but lower these in production if possible.
APP_UPLOAD_MAX_IMAGE_BYTES=15728640
APP_UPLOAD_MAX_MEDIA_BYTES=104857600
APP_UPLOAD_MAX_ATTACHMENT_BYTES=52428800
